
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information stored in Firestore",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["customer", "merchant", "rider"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "Food delivery order record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "restaurantId": { "type": "string" },
        "riderId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "out-for-delivery", "delivered", "cancelled"] },
        "deliveryAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and roles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "System orders"
    }
  }
}
